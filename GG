        if isfile and isfile(ConfigName) then
            local suc, dec = pcall(function() return HttpService:JSONDecode(readfile(ConfigName)) end)
            if suc and type(dec) == "table" then for k, v in pairs(dec) do CurrentConfig[k] = v end end
        end
        for k, v in pairs(DefaultConfig) do if CurrentConfig[k] == nil then CurrentConfig[k] = v end end
